# Debitura MCP server — local/self-hosted configuration.
# Copy to `.env` (or export these) when running locally. The hosted service at
# https://mcp.debitura.com/mcp does not need any of this.

# Port the Streamable HTTP MCP endpoint listens on (POST /mcp).
PORT=3000

# Base URL of the Debitura Customer API to proxy.
# Production: https://customer-api.debitura.com
# Test:       https://testcustomer-api.debitura.com
DEBITURA_API_BASE_URL=https://customer-api.debitura.com

# --- E2E tests only (scripts/e2e.ts) ---
# A Debitura API key for the TEST environment. Never use a production key here.
# DEBITURA_TEST_API_KEY=
# MCP_URL=http://localhost:3000/mcp
